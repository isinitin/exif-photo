{
	"name": "exif-photo",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types --check && vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"gen": "wrangler types",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:local": "npx wrangler d1 migrations apply DB --local",
		"db:remote": "npx wrangler d1 migrations apply DB --remote",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@ark-ui/svelte": "^5.22.1",
		"@better-auth/cli": "^1.4.21",
		"@ethercorps/sveltekit-og": "^4.2.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tabler/icons-svelte-runes": "^3.44.0",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.2",
		"@tanstack/svelte-form": "^1.33.0",
		"@types/node": "^24.13.2",
		"better-auth": "~1.4.21",
		"cnfast": "^0.0.8",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"exifreader": "^4.41.0",
		"nanoid": "^5.1.16",
		"oxfmt": "^0.55.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.3.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"valibot": "^1.4.2",
		"vite": "^8.1.3",
		"wrangler": "^4.107.0"
	}
}
